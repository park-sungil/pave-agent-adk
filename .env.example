# LLM Configuration
LLM_MODEL=openai/glm-4.7
LLM_MODEL_ANALYZE=           # (optional) override for analyze tool
LLM_MODEL_INTERPRET=         # (optional) override for interpret tool

# Flip this to switch — both config blocks below can stay populated
LLM_AUTH_METHOD=key          # key | header

# Method "key"
LLM_API_BASE_KEY=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here

# Method "header"
LLM_API_BASE_HEADER=http://localhost:8001/v1
LLM_API_HEADER_NAME=Authorization
LLM_API_HEADER_VALUE=Bearer your-token-here

# Oracle DB
ORACLE_DSN=localhost:1521/pavedb
ORACLE_USER=pave
ORACLE_PASSWORD=your-password-here

# Logging
LOG_LEVEL=INFO
