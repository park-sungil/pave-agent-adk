# LLM Configuration
LLM_MODEL=openai/glm-4.7
LLM_MODEL_ANALYZE=           # (optional) override for analyze tool, key mode only
LLM_MODEL_INTERPRET=         # (optional) override for interpret tool, key mode only

# Flip to switch — both blocks below can stay populated
LLM_AUTH=key                 # key | header

# Method "key"
LLM_API_BASE_KEY=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here

# Method "header" (vLLM)
LLM_API_BASE_HEADER=https://your-internal-vllm-endpoint
VLLM_DEP_TICKET=your_credential_key
VLLM_SEND_SYSTEM_NAME=test_api_1
VLLM_USER_ID=your_knox_id
VLLM_USER_TYPE=your_ad_id

# Oracle DB
ORACLE_DSN=localhost:1521/pavedb
ORACLE_USER=pave
ORACLE_PASSWORD=your-password-here

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Logging
LOG_LEVEL=INFO
