# LLM Configuration
LLM_MODEL=openai/glm-4.7
LLM_MODEL_ANALYZE=           # (optional) override for analyze tool
LLM_MODEL_INTERPRET=         # (optional) override for interpret tool
LLM_API_BASE=http://localhost:8000/v1

# Auth method: "key" or "header"
LLM_AUTH_METHOD=key

# Used when LLM_AUTH_METHOD=key
LLM_API_KEY=your-api-key-here

# Used when LLM_AUTH_METHOD=header
LLM_API_HEADER_NAME=Authorization
LLM_API_HEADER_VALUE=

# Oracle DB
ORACLE_DSN=localhost:1521/pavedb
ORACLE_USER=pave
ORACLE_PASSWORD=your-password-here

# Logging
LOG_LEVEL=INFO
